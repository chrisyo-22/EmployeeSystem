<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.chrisyo.mapper.StudentMapper">
    <select id="page" resultType="com.chrisyo.entity.Student">
        select s.*, c.name className
        from student s left join class c on s.class_id = c.id
        <where>
            <if test="name !=null and name != ''">
                s.name like concat('%', #{name}, '%')
            </if>
            <if test="degree != null"> and s.degree = #{degree}</if>
            <if test="classId != null"> and s.class_Id = #{classId}</if>
        </where>
    </select>

    <delete id="delete">
        delete from student where id in
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </delete>

    <select id="getById" resultType="com.chrisyo.entity.Student">
        select * from student where id = #{id}
    </select>

    <insert id="add">
        insert into student values(null, #{name}, #{no}, #{gender}, #{phone}, #{idCard}, #{isCollege}, #{address}, #{degree}, #{graduationDate}, #{classId}, #{violationCount}, #{violationScore}, #{createTime}, #{updateTime})
    </insert>
</mapper>